  "tokenColors": [
    {
      "name": "Comments",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#7a8573", "fontStyle": "italic" }
    },
    {
      "name": "Strings",
      "scope": ["string", "string.quoted"],
      "settings": { "foreground": "#8fb339" }
    },
    {
      "name": "String escape",
      "scope": ["constant.character.escape", "string.regexp"],
      "settings": { "foreground": "#a0c04a" }
    },
    {
      "name": "Numbers",
      "scope": ["constant.numeric"],
      "settings": { "foreground": "#b07878" }
    },
    {
      "name": "Boolean / null",
      "scope": ["constant.language"],
      "settings": { "foreground": "#c09060", "fontStyle": "bold" }
    },
    {
      "name": "Constants",
      "scope": ["constant", "variable.other.constant"],
      "settings": { "foreground": "#c08888" }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "storage.modifier",
        "storage.type"
      ],
      "settings": { "foreground": "#c25d44", "fontStyle": "bold" }
    },
    {
      "name": "Operators",
      "scope": ["keyword.operator"],
      "settings": { "foreground": "#c09060" }
    },
    {
      "name": "Functions",
      "scope": [
        "entity.name.function",
        "meta.function-call",
        "support.function"
      ],
      "settings": { "foreground": "#7eb2d1" }
    },
    {
      "name": "Types / Classes",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.class",
        "support.type"
      ],
      "settings": { "foreground": "#a67c52" }
    },
    {
      "name": "Variables",
      "scope": ["variable", "variable.other"],
      "settings": { "foreground": "#dce0d9" }
    },
    {
      "name": "Parameters",
      "scope": ["variable.parameter"],
      "settings": { "foreground": "#ecf0e9" }
    },
    {
      "name": "Properties / Members",
      "scope": ["variable.other.property", "variable.other.object.property"],
      "settings": { "foreground": "#ecf0e9" }
    },
    {
      "name": "Built-in variables",
      "scope": ["variable.language"],
      "settings": { "foreground": "#d46848", "fontStyle": "italic" }
    },
    {
      "name": "Tags (HTML/JSX)",
      "scope": ["entity.name.tag"],
      "settings": { "foreground": "#c25d44" }
    },
    {
      "name": "Tag attributes",
      "scope": ["entity.other.attribute-name"],
      "settings": { "foreground": "#a67c52" }
    },
    {
      "name": "Imports / Namespaces",
      "scope": ["entity.name.namespace", "meta.import"],
      "settings": { "foreground": "#5ea89a" }
    },
    {
      "name": "Decorators / Annotations",
      "scope": ["meta.decorator", "punctuation.decorator"],
      "settings": { "foreground": "#b07878" }
    },
    {
      "name": "Punctuation",
      "scope": ["punctuation", "meta.brace"],
      "settings": { "foreground": "#a8b09f" }
    },
    {
      "name": "Markdown — headings",
      "scope": ["markup.heading", "entity.name.section"],
      "settings": { "foreground": "#c09060", "fontStyle": "bold" }
    },
    {
      "name": "Markdown — bold",
      "scope": ["markup.bold"],
      "settings": { "foreground": "#ecf0e9", "fontStyle": "bold" }
    },
    {
      "name": "Markdown — italic",
      "scope": ["markup.italic"],
      "settings": { "fontStyle": "italic" }
    },
    {
      "name": "Markdown — code",
      "scope": ["markup.inline.raw", "markup.fenced_code"],
      "settings": { "foreground": "#8fb339" }
    },
    {
      "name": "Markdown — links",
      "scope": ["markup.underline.link"],
      "settings": { "foreground": "#7eb2d1" }
    },
    {
      "name": "Markdown — blockquote",
      "scope": ["markup.quote"],
      "settings": { "foreground": "#7a8573", "fontStyle": "italic" }
    },
    {
      "name": "Markdown — list",
      "scope": ["markup.list", "punctuation.definition.list"],
      "settings": { "foreground": "#c09060" }
    },
    {
      "name": "CSS — property",
      "scope": ["support.type.property-name.css"],
      "settings": { "foreground": "#7eb2d1" }
    },
    {
      "name": "CSS — value",
      "scope": ["support.constant.property-value"],
      "settings": { "foreground": "#8fb339" }
    },
    {
      "name": "CSS — selector",
      "scope": ["entity.other.attribute-name.class.css", "entity.other.attribute-name.id.css"],
      "settings": { "foreground": "#a67c52" }
    },
    {
      "name": "Invalid",
      "scope": ["invalid"],
      "settings": { "foreground": "#ecf0e9", "background": "#c25d44" }
    },
    {
      "name": "Deprecated",
      "scope": ["invalid.deprecated"],
      "settings": { "foreground": "#ecf0e9", "background": "#b07878" }
    }
  ]
}
