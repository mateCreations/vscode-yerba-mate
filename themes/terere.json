  "tokenColors": [
    {
      "name": "Comments",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#928374", "fontStyle": "italic" }
    },
    {
      "name": "Strings",
      "scope": ["string", "string.quoted"],
      "settings": { "foreground": "#79740e" }
    },
    {
      "name": "String escape",
      "scope": ["constant.character.escape", "string.regexp"],
      "settings": { "foreground": "#8c8c08" }
    },
    {
      "name": "Numbers",
      "scope": ["constant.numeric"],
      "settings": { "foreground": "#8f3f71" }
    },
    {
      "name": "Boolean / null",
      "scope": ["constant.language"],
      "settings": { "foreground": "#b57614", "fontStyle": "bold" }
    },
    {
      "name": "Constants",
      "scope": ["constant", "variable.other.constant"],
      "settings": { "foreground": "#9d4f7d" }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "storage.modifier",
        "storage.type"
      ],
      "settings": { "foreground": "#9d0006", "fontStyle": "bold" }
    },
    {
      "name": "Operators",
      "scope": ["keyword.operator"],
      "settings": { "foreground": "#c88010" }
    },
    {
      "name": "Functions",
      "scope": [
        "entity.name.function",
        "meta.function-call",
        "support.function"
      ],
      "settings": { "foreground": "#076678" }
    },
    {
      "name": "Types / Classes",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.class",
        "support.type"
      ],
      "settings": { "foreground": "#b57614" }
    },
    {
      "name": "Variables",
      "scope": ["variable", "variable.other"],
      "settings": { "foreground": "#3c3836" }
    },
    {
      "name": "Parameters",
      "scope": ["variable.parameter"],
      "settings": { "foreground": "#504945" }
    },
    {
      "name": "Properties / Members",
      "scope": ["variable.other.property", "variable.other.object.property"],
      "settings": { "foreground": "#504945" }
    },
    {
      "name": "Built-in variables",
      "scope": ["variable.language"],
      "settings": { "foreground": "#af1010", "fontStyle": "italic" }
    },
    {
      "name": "Tags (HTML/JSX)",
      "scope": ["entity.name.tag"],
      "settings": { "foreground": "#9d0006" }
    },
    {
      "name": "Tag attributes",
      "scope": ["entity.other.attribute-name"],
      "settings": { "foreground": "#b57614" }
    },
    {
      "name": "Imports / Namespaces",
      "scope": ["entity.name.namespace", "meta.import"],
      "settings": { "foreground": "#427b58" }
    },
    {
      "name": "Decorators / Annotations",
      "scope": ["meta.decorator", "punctuation.decorator"],
      "settings": { "foreground": "#8f3f71" }
    },
    {
      "name": "Punctuation",
      "scope": ["punctuation", "meta.brace"],
      "settings": { "foreground": "#665c54" }
    },
    {
      "name": "Markdown — headings",
      "scope": ["markup.heading", "entity.name.section"],
      "settings": { "foreground": "#b57614", "fontStyle": "bold" }
    },
    {
      "name": "Markdown — bold",
      "scope": ["markup.bold"],
      "settings": { "foreground": "#1c1816", "fontStyle": "bold" }
    },
    {
      "name": "Markdown — italic",
      "scope": ["markup.italic"],
      "settings": { "fontStyle": "italic" }
    },
    {
      "name": "Markdown — code",
      "scope": ["markup.inline.raw", "markup.fenced_code"],
      "settings": { "foreground": "#79740e" }
    },
    {
      "name": "Markdown — links",
      "scope": ["markup.underline.link"],
      "settings": { "foreground": "#076678" }
    },
    {
      "name": "Markdown — blockquote",
      "scope": ["markup.quote"],
      "settings": { "foreground": "#928374", "fontStyle": "italic" }
    },
    {
      "name": "Markdown — list",
      "scope": ["markup.list", "punctuation.definition.list"],
      "settings": { "foreground": "#c88010" }
    },
    {
      "name": "CSS — property",
      "scope": ["support.type.property-name.css"],
      "settings": { "foreground": "#076678" }
    },
    {
      "name": "CSS — value",
      "scope": ["support.constant.property-value"],
      "settings": { "foreground": "#79740e" }
    },
    {
      "name": "CSS — selector",
      "scope": ["entity.other.attribute-name.class.css", "entity.other.attribute-name.id.css"],
      "settings": { "foreground": "#b57614" }
    },
    {
      "name": "Invalid",
      "scope": ["invalid"],
      "settings": { "foreground": "#fbf1c7", "background": "#9d0006" }
    },
    {
      "name": "Deprecated",
      "scope": ["invalid.deprecated"],
      "settings": { "foreground": "#fbf1c7", "background": "#8f3f71" }
    }
  ]
}
